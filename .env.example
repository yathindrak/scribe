# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# Google OAuth 
# https://console.cloud.google.com/ → APIs & Services → Credentials
export GOOGLE_CLIENT_ID=
export GOOGLE_CLIENT_SECRET=
export GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Recall.ai
# https://www.recall.ai/
export RECALL_API_KEY=
export RECALL_REGION=us-west-2

# Google Gemini ─
# https://aistudio.google.com/app/apikey
export GEMINI_API_KEY=

# LinkedIn OAuth 
# https://www.linkedin.com/developers/ → Create App
export LINKEDIN_CLIENT_ID=
export LINKEDIN_CLIENT_SECRET=
export LINKEDIN_REDIRECT_URI=http://localhost:4000/auth/linkedin/callback

# Facebook OAuth 
# https://developers.facebook.com → My Apps → Create App
export FACEBOOK_APP_ID=
export FACEBOOK_APP_SECRET=
export FACEBOOK_CLIENT_ID=
export FACEBOOK_CLIENT_SECRET=
export FACEBOOK_REDIRECT_URI=http://localhost:4000/auth/facebook/callback

# HubSpot OAuth ─
# https://developers.hubspot.com/ → Create App
# Required scopes: crm.objects.contacts.read, crm.objects.contacts.write
export HUBSPOT_CLIENT_ID=
export HUBSPOT_CLIENT_SECRET=
export HUBSPOT_REDIRECT_URI=http://localhost:4000/auth/hubspot/callback

# Salesforce OAuth 
# Setup → Apps > App Manager → New Connected App
# Required scopes: api, refresh_token / offline_access
export SALESFORCE_CLIENT_ID=
export SALESFORCE_CLIENT_SECRET=
export SALESFORCE_REDIRECT_URI=http://localhost:4000/auth/salesforce/callback

# Database (production). Locally comment this out if using docker
# export DATABASE_URL=
